  "keyFeatures": [
    "Auto-generated hooks from RTK Query API definitions",
    "Signal-based reactivity for fine-grained change detection",
    "Works with or without NgRx Store (provideStoreApi vs provideNoopStoreApi)",
    "Support for queries, lazy queries, infinite queries, and mutations",
    "Integration with Angular's dependency injection (HttpClient support)",
    "Tag-based cache invalidation",
    "TypeScript first with full type safety"
  ],
  "publicApiSurface": [
    "createApi",
    "fetchBaseQuery",
    "provideStoreApi",
    "provideNoopStoreApi",
    "useXxxQuery",
    "useLazyXxxQuery",
    "useXxxInfiniteQuery",
    "useXxxMutation",
    "skipToken",
    "angularHooksModule"
  ]
